generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model boards {
  id         Int       @id @default(autoincrement())
  name       String    @db.VarChar(255)
  created_by Int?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  users      users?    @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tasks      tasks[]
}

model comments {
  id         Int       @id @default(autoincrement())
  task_id    Int?
  user_id    Int?
  comment    String
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  tasks      tasks?    @relation(fields: [task_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model meeting_comments {
  id                  Int               @id @default(autoincrement())
  meeting_schedule_id Int?
  user_id             Int?
  comment             String
  image_url           String?           @db.VarChar(500)
  created_at          DateTime?         @default(now()) @db.Timestamptz(6)
  meeting_schedule    meeting_schedule? @relation(fields: [meeting_schedule_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users               users?            @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model meeting_room {
  id               String             @id @db.VarChar(255) 
  
  name             String             @db.VarChar(255)
  location         String?            @db.VarChar(255)
  capacity         Int?
  password         String?            @db.VarChar(255)     
  
  meeting_schedule meeting_schedule[]
}

model meeting_schedule {
  id               Int                @id @default(autoincrement())
  
  meeting_room_id  String?            @db.VarChar(255)     
  
  start_time       DateTime           @db.Timestamptz(6)
  end_time         DateTime           @db.Timestamptz(6)
  meeting_comments meeting_comments[]
  meeting_room     meeting_room?      @relation(fields: [meeting_room_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model notifications {
  id         Int       @id @default(autoincrement())
  user_id    Int?
  message    String
  is_read    Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model tasks {
  id                             Int        @id @default(autoincrement())
  board_id                       Int?
  title                          String     @db.VarChar(255)
  description                    String?
  status                         String?    @default("TODO") @db.VarChar(50)
  due_date                       DateTime?  @db.Timestamptz(6)
  assigned_to                    Int?
  created_by                     Int?
  updated_by                     Int?
  created_at                     DateTime?  @default(now()) @db.Timestamptz(6)
  updated_at                     DateTime?  @default(now()) @db.Timestamptz(6)
  comments                       comments[]
  users_tasks_assigned_toTousers users?     @relation("tasks_assigned_toTousers", fields: [assigned_to], references: [id], onDelete: NoAction, onUpdate: NoAction)
  boards                         boards?    @relation(fields: [board_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_tasks_created_byTousers  users?     @relation("tasks_created_byTousers", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_tasks_updated_byTousers  users?     @relation("tasks_updated_byTousers", fields: [updated_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model users {
  id                             Int                @id @default(autoincrement())
  username                       String             @db.VarChar(255) @unique
  password                       String             @db.VarChar(255)
  email                          String             @unique @db.VarChar(255)
  created_at                     DateTime?          @default(now()) @db.Timestamptz(6)
  updated_at                     DateTime?          @default(now()) @db.Timestamptz(6)
  boards                         boards[]
  comments                       comments[]
  meeting_comments               meeting_comments[]
  notifications                  notifications[]
  tasks_tasks_assigned_toTousers tasks[]            @relation("tasks_assigned_toTousers")
  tasks_tasks_created_byTousers  tasks[]            @relation("tasks_created_byTousers")
  tasks_tasks_updated_byTousers  tasks[]            @relation("tasks_updated_byTousers")
}
